<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lost in Pages Tickets Policy </title>

<link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Playfair+Display:wght@400;600&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

<style>
:root{
    --midnight:#4838DB;
    --magic:#FFFFFF;
    --accent:#9932CC;
}

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:'Inter',sans-serif;
    color:white;
    background: var(--midnight);
    position: relative;
    overflow-x: hidden;
}

/* STAR LAYERS */
#stars, #shooting-stars{
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
}

/* STAR STYLE */
.star{
    position:absolute;
    width:2px;
    height:2px;
    background:white;
    border-radius:50%;
    opacity:0.8;
    animation: twinkle 3s infinite ease-in-out;
}

@keyframes twinkle {
    0%, 100% { opacity: 0.2; }
    50% { opacity: 1; }
}

/* CONTENT ABOVE STARS */
header, .container, footer{
    position: relative;
    z-index: 1;
}

header{
    text-align:center;
    padding:70px 20px;
}

h1{
    font-family:'Great Vibes', cursive;
    font-size:4rem;
    margin-bottom:10px;
}

.subtitle{
    color:#F8F8FF;
}

.container{
    max-width:1000px;
    margin:40px auto;
    padding:0 20px;
}

.policy{
    background:white;
    color:#9932CC;
    padding:30px;
    margin-bottom:25px;
    border-radius:18px;
    border:2px solid #9932CC;
    box-shadow:0 0 20px rgba(0,0,0,.15);
    text-align: center;
}

.policy h2{
    font-family:'Playfair Display', serif;
    margin-bottom:15px;
}

.policy p{
    line-height:1.8;
}

.back{
    display:inline-block;
    margin:40px auto;
    padding:14px 30px;
    background:white;
    color:#483D8B;
    text-decoration:none;
    border-radius:10px;
    font-weight:600;
    transition:0.2s ease;
}

.back:hover{
    transform:translateY(-2px);
}

footer{
    text-align:center;
    padding:40px;
    color:white;
}
</style>
</head>

<body>

<!-- STAR BACKGROUND LAYERS -->
<div id="stars"></div>
<div id="shooting-stars"></div>

<header>
    <h1>Our Policies</h1>
    <p class="subtitle">Tickets and Attendance Policy

